# RAG 配置文件示例
# 复制此文件为 settings.yaml 并填入你的 API key

llm:
  provider: "openai"
  model: "mimo-v2.5-pro"
  base_url: "https://token-plan-cn.xiaomimimo.com/v1"
  api_key: "YOUR_MIMO_API_KEY"  # 替换为你的 API key
  temperature: 0.0
  max_tokens: 4096

vision_llm:
  provider: "openai"
  model: "mimo-v2.5"
  base_url: "https://token-plan-cn.xiaomimimo.com/v1"
  api_key: "YOUR_MIMO_API_KEY"  # 替换为你的 API key
  temperature: 0.0
  max_tokens: 4096

ollama:
  model: "gemma4"
  base_url: "http://localhost:11434"
  temperature: 0.0
  max_tokens: 4096

embedding:
  provider: "bge"
  model: "bge-m3"
  dimensions: 1024
  model_path: "models/bge-m3"
  api_key: ""

splitter:
  strategy: "recursive"
  chunk_size: 1000
  chunk_overlap: 200
  separators: []
  keep_code_blocks: true
  keep_headers: true

vector_store:
  provider: "chroma"
  persist_directory: "data/db/chroma"

retrieval:
  top_k: 10
  hybrid: true

rerank:
  enabled: false
  provider: "none"
  model: ""
  top_k: 5

evaluation:
  backends: ["custom"]

observability:
  log_level: "INFO"
  traces_file: "logs/traces.jsonl"
